PROJECT_NAME           = "HFT Signal Processing Stack"
PROJECT_BRIEF          = "Production-Grade C++26/VHDL/ASM Monorepo"
OUTPUT_DIRECTORY       = gen
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HAVE_DOT               = YES
EXTRACT_ALL            = YES
RECURSIVE              = YES

# Multi-Language Support
# Run from 'docs' dir. index.md is the entry point.
INPUT                  = index.md \
                         introduction.md \
                         getting_started.md \
                         requirements.md \
                         hardware.md \
                         networking.md \
                         signals.md \
                         optimization.md \
                         cpp26_features.md \
                         verification.md \
                         benchmarking.md \
                         citations.md \
                         ../libs \
                         ../hardware/asm \
                         ../hardware/vhdl \
                         ../technical_specification

# EXPLICITLY EXCLUDE README to avoid it becoming the main page
EXCLUDE                = ../README.md

EXAMPLE_PATH           = ..
FILE_PATTERNS          = *.hpp *.cpp *.h *.vhd *.s *.asm *.md
EXTENSION_MAPPING      = vhd=vhdl s=C asm=C

# Force index.md as the main page
USE_MDFILE_AS_MAINPAGE = index.md
HTML_HEADER            = header.html

# VHDL Specifics
OPTIMIZE_OUTPUT_VHDL   = YES

# Modern UI (Doxygen Awesome)
HTML_EXTRA_STYLESHEET  = https://raw.githubusercontent.com/jothepro/doxygen-awesome-css/main/doxygen-awesome.css
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = YES

# MathJax for equations
USE_MATHJAX            = YES
MATHJAX_FORMAT         = HTML-CSS
MATHJAX_RELPATH        = https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.5/
MATHJAX_EXTENSIONS     = TeX/AMSmath TeX/AMSsymbols

# Source Browser
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES

# Markdown support
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
