PROJECT_NAME           = "HFT Signal Processing Stack"
OUTPUT_DIRECTORY       = docs/gen
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HAVE_DOT               = YES
EXTRACT_ALL            = YES
RECURSIVE              = YES

# Multi-Language Support
INPUT                  = docs libs hardware/asm hardware/vhdl README.md technical_specification
FILE_PATTERNS          = *.hpp *.cpp *.h *.vhd *.s *.asm *.md
EXTENSION_MAPPING      = vhd=vhdl s=C asm=C

# Main Page and Layout
USE_MDFILE_AS_MAINPAGE = docs/manual.md
HTML_HEADER            = docs/header.html

# VHDL Specifics
OPTIMIZE_OUTPUT_VHDL   = YES

# Modern UI (Doxygen Awesome)
HTML_EXTRA_STYLESHEET  = https://raw.githubusercontent.com/jothepro/doxygen-awesome-css/main/doxygen-awesome.css
GENERATE_TREEVIEW      = YES

# MathJax for equations
USE_MATHJAX            = YES
MATHJAX_FORMAT         = HTML-CSS
MATHJAX_RELPATH        = https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.5/
MATHJAX_EXTENSIONS     = TeX/AMSmath TeX/AMSsymbols

# Source Browser
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES

# Markdown support
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
